# Copy config/watcher.example.json to config/watcher.local.json before first run.
STREAM_WATCH_CONFIG=./config/watcher.local.json
STREAM_WATCH_RACKNERD_ROOT_PASSWORD=

# Optional SMTP sender settings for email notifications.
# The app will still run if these are left empty.
STREAM_WATCH_SMTP_HOST=
STREAM_WATCH_SMTP_PORT=587
STREAM_WATCH_SMTP_SECURE=false
STREAM_WATCH_SMTP_USER=
STREAM_WATCH_SMTP_PASS=
STREAM_WATCH_SMTP_FROM=

STREAM_WATCH_WEB_HOST=127.0.0.1
STREAM_WATCH_WEB_PORT=3030
